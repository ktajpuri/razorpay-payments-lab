# Razorpay TEST mode keys — Dashboard > Account & Settings > API Keys > Generate (Test Mode)
# These are instant; no KYC needed for test mode.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret — Dashboard > Settings > Webhooks (set when you create the webhook).
# This is SEPARATE from the API key secret.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Optional
PORT=3000
DB_PATH=./payments.db
ABANDON_AFTER_MS=900000
